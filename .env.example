# AegisMem Environment Configuration
# Copy to .env and fill in values

# Application
APP_ENV=development
APP_SECRET_KEY=your-secret-key-change-in-production
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aegismem
POSTGRES_USER=aegismem
POSTGRES_PASSWORD=aegismem_password

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=aegismem_memories

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=aegismem_password

# LLM Providers (set at least one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Embedding model
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_BACKEND=sentence_transformers

# Default LLM provider: openai | anthropic | local
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# Memory settings
MEMORY_IMPORTANCE_THRESHOLD=0.3
MEMORY_MAX_WORKING_TOKENS=4096
REFLECTION_TRIGGER_COUNT=10
